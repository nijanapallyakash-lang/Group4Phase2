@model Group4Flight.Models.Flight
@{
    Layout = "_MainLayout";
    ViewData["Title"] = $"Flight {Model.FlightCode} Details";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
                <h4 class="mb-0">Flight @Model.FlightCode</h4>
                <span class="badge bg-light text-dark fs-6">@Model.Date.ToString("MMMM dd, yyyy")</span>
            </div>
            
            <div class="card-body p-4">
                <div class="row mb-4 align-items-center">
                    <div class="col-md-6">
                        <h5 class="text-muted mb-1">Airline</h5>
                        <div class="d-flex align-items-center fs-5 fw-bold">
                            @if (Model.Airline != null && !string.IsNullOrEmpty(Model.Airline.ImageName))
                            {
                                <img src="~/images/@Model.Airline.ImageName" alt="@Model.Airline.Name" style="height: 35px; margin-right: 15px;" onerror="this.style.display='none'" />
                            }
                            @Model.Airline?.Name
                        </div>
                    </div>
                    <div class="col-md-6 text-md-end mt-3 mt-md-0">
                        <h5 class="text-muted mb-1">Total Cost</h5>
                        <div class="fs-3 text-success fw-bold">$@Model.Price.ToString("0.00")</div>
                    </div>
                </div>

                <hr class="text-muted" />

                <div class="row text-center my-4">
                    <div class="col-4">
                        <h2 class="text-dark fw-bold mb-0">@Model.From</h2>
                        <p class="text-muted fs-5 mt-2">@Model.DepartureTime.ToString(@"hh\:mm")</p>
                    </div>
                    <div class="col-4 d-flex flex-column justify-content-center align-items-center">
                        @{
                            var dur = Model.ArrivalTime - Model.DepartureTime;
                            if (dur < TimeSpan.Zero) dur = dur.Add(TimeSpan.FromHours(24));
                        }
                        <span class="text-muted small fw-bold">@($"{(int)dur.TotalHours}h {dur.Minutes}m")</span>
                        <span class="fs-1 text-primary">✈️</span>
                    </div>
                    <div class="col-4">
                        <h2 class="text-dark fw-bold mb-0">@Model.To</h2>
                        <p class="text-muted fs-5 mt-2">@Model.ArrivalTime.ToString(@"hh\:mm")</p>
                    </div>
                </div>

                <hr class="text-muted" />

                <div class="row mt-4 text-center">
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <span class="text-muted d-block mb-1">Cabin</span>
                        <span class="fw-bold fs-6">@Model.CabinType</span>
                    </div>
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <span class="text-muted d-block mb-1">Aircraft</span>
                        <span class="fw-bold fs-6">@Model.AircraftType</span>
                    </div>
                    <div class="col-sm-4">
                        <span class="text-muted d-block mb-1">CO2 Emission</span>
                        <span class="fw-bold fs-6">@Model.Emission.ToString("F1") kg</span>
                    </div>
                </div>
            </div>
            
            <div class="card-footer bg-light p-3 d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-outline-secondary">← Back to Search</a>

                @if (ViewBag.IsSelected != null && (bool)ViewBag.IsSelected)
                {
                    <button class="btn btn-success px-4" disabled>✓ Selected</button>
                }
                else
                {
                    <form asp-action="Select" method="post" class="m-0">
                        <input type="hidden" name="flightId" value="@Model.FlightId" />
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Select Flight</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>